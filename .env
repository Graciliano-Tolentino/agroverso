# ============================================
# 📄 Projeto: Agroverso
# 📁 Arquivo: .env.example
# ✍️ Autor: Equipe Agroverso
# 📅 Criado em: 07/05/2025
# 📝 Descrição:
#   Modelo de variáveis de ambiente do frontend Agroverso.
#   Utilize este arquivo como base para configurar o `.env`
#   de desenvolvimento, staging ou produção.
#   ⚠️ Nunca comite o `.env` real com dados sensíveis.
# ============================================

# 🌐 URL base da API do backend (RESTful ou GraphQL)
VITE_API_BASE_URL=https://api.agroverso.tec.br

# 🧭 Ambiente da aplicação
# development | staging | production | test
APP_ENV=development

# 🌱 Nome do projeto (exibido em logs ou metadados)
VITE_PROJECT_NAME=Agroverso

# 📊 Ativação de ferramentas analíticas (futuro)
VITE_USE_GOOGLE_ANALYTICS=false

# 🧪 Habilita dados falsos para testes e dev
VITE_ENABLE_FAKE_DATA=true

# 📣 Identificadores opcionais (comentados por padrão)
# VITE_ANALYTICS_ID=UA-XXXXXXX-X
# VITE_SENTRY_DSN=https://example.sentry.io/xxxxxxx

# ============================================
# 📦 Instruções:
# 1. Copie este arquivo como `.env` na raiz do projeto
# 2. Preencha os valores conforme seu ambiente real
# 3. Certifique-se de que `.env` está no `.gitignore`
# ============================================
